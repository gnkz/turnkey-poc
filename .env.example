# Public identifiers from Turnkey Dashboard -> Embedded Wallets -> Configuration.
NEXT_PUBLIC_TURNKEY_ORGANIZATION_ID=
NEXT_PUBLIC_TURNKEY_AUTH_PROXY_CONFIG_ID=

# Optional public Ethereum RPC URL for balances and contract previews. The app
# falls back to viem's Ethereum mainnet public RPC when this is blank.
NEXT_PUBLIC_ETHEREUM_RPC_URL=

# Turnkey Gas Sponsorship is an Enterprise feature. When false, the embedded
# wallet must hold enough ETH to pay for the EIP-7702 batch.
NEXT_PUBLIC_TURNKEY_SPONSOR_TRANSACTIONS=false

# Turnkey currently requires an explicit outer gas limit for non-sponsored V2
# batches. This conservative PoC ceiling is not an eth_estimateGas result.
NEXT_PUBLIC_NON_SPONSORED_BATCH_GAS_LIMIT=750000

# Deliberate safety gate: contract addresses in this PoC are Ethereum mainnet.
# Quotes still work when false, but transaction submission remains disabled.
NEXT_PUBLIC_ENABLE_MAINNET_TRANSACTIONS=false
